# pyenv
#   For a library or package, you might want to ignore these files since the 
#   project is intended to be used by multiple python versions.
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if you choose not to, then uncomment the following line:
# .Pipfile.lock

# poetry
#   Similar to Pipfile.lock, it is generally recommended to include poetry.lock in version control.
#   Stay tuned to python-poetry/poetry#1637 and python-poetry/poetry#423 for further discussion.
# poetry.lock

# pdm
#   Similar to Pipfile.lock, it is generally recommended to include pdm.lock in version control.
# .pdm.lock
#   pdm-specific environment variables files
.pdm-python
.pdm-build/

# PEP 582; used by e.g. github.com/frenzy/pdm
__pypackages__/

